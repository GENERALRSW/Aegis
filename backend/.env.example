# ─── AEGIS Backend — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
DEBUG=false

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-random-64-char-hex-string

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=aegis_db

# ── Event Broker ───────────────────────────────────────────────────────────────
BROKER=kafka                              # kafka | rabbitmq
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── LLM (Gemini) ───────────────────────────────────────────────────────────────
# Backend-only. NEVER put AI API keys in the frontend .env
LLM_ENABLED=true
GEMINI_API_KEY=                           # Get from Google AI Studio

# ── Computer Vision ────────────────────────────────────────────────────────────
YOLO_MODEL_PATH=yolov8n.pt
DEVICE=cpu                                # cpu | cuda | mps

# ── Cloudinary (photo storage) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=                    # Keep this server-side only

# ── Firebase Cloud Messaging ───────────────────────────────────────────────────
FCM_CREDENTIALS_PATH=firebase_credentials.json
FCM_PROJECT_ID=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
